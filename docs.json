{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Lazy Raccoon",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "getting-started/installation",
              "getting-started/quickstart",
              "getting-started/authentication"
            ]
          },
          {
            "group": "CLI Commands",
            "pages": [
              "cli/push",
              "cli/pull",
              "cli/status",
              "cli/whoami"
            ]
          },
          {
            "group": "Supported Tools",
            "pages": [
              "tools/overview",
              "tools/claude",
              "tools/cursor",
              "tools/copilot",
              "tools/gemini",
              "tools/windsurf",
              "tools/cline"
            ]
          },
          {
            "group": "Teams",
            "pages": [
              "teams/overview",
              "teams/creating-a-team",
              "teams/invitations",
              "teams/roles-and-permissions",
              "teams/team-configs"
            ]
          },
          {
            "group": "Plans & Billing",
            "pages": [
              "plans"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Configs",
            "pages": [
              "api-reference/configs/list",
              "api-reference/configs/push",
              "api-reference/configs/get-latest",
              "api-reference/configs/get-by-id",
              "api-reference/configs/delete"
            ]
          },
          {
            "group": "Versions",
            "pages": [
              "api-reference/versions/list",
              "api-reference/versions/get",
              "api-reference/versions/rollback"
            ]
          },
          {
            "group": "Teams",
            "pages": [
              "api-reference/teams/list",
              "api-reference/teams/create",
              "api-reference/teams/get",
              "api-reference/teams/update",
              "api-reference/teams/delete"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://lazyraccoon.dev",
          "icon": "globe"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/fpuglap/lazy-raccoon-cli",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://lazyraccoon.dev/dashboard"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://lazyraccoon.dev/sign-up"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/fpuglap/lazy-raccoon-cli",
      "website": "https://lazyraccoon.dev"
    }
  }
}
